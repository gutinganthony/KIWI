//@version=5
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//   AVI Composite Dashboard — CPI + TSI + AVI in one panel
//   Generated by AVI V5 Dashboard
//
//   HOW TO USE:
//   1. Run `python3 scripts/run_dashboard.py --pine` to update values below.
//   2. Paste into TradingView Pine Editor → Add to Chart.
//
//   Scale: All three scores normalized to 0-100
//     CPI  (0-100): Crash Probability Index — broad market
//     TSI  (0-100): Tech Stress Index — tech/semis sector
//     AVI  (0-10 → ×10 = 0-100): Monthly valuation risk
//
//   Thresholds:
//     70+  = Critical / extreme danger
//     50+  = High risk
//     35+  = Elevated
//     20+  = Moderate
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

indicator("AVI Composite — CPI + TSI + AVI", overlay=false, precision=1)

// ── Static Values (auto-updated by run_dashboard.py --pine) ──
// {{PINE_VALUES_START}}
CPI_SCORE  = {{CPI_SCORE}}
TSI_SCORE  = {{TSI_SCORE}}
AVI_SCORE  = {{AVI_SCORE_X10}}   // AVI original × 10  (e.g. 6.73 → 67.3)
AVI_RAW    = {{AVI_SCORE_RAW}}   // Original 0-10 value
UPDATE_DATE = "{{UPDATE_DATE}}"

CPI_LEVEL  = "{{CPI_LEVEL}}"
TSI_BIAS   = "{{TSI_BIAS}}"
AVI_LABEL  = "{{AVI_LABEL}}"
// {{PINE_VALUES_END}}

// ── Colors ──
cpi_color = CPI_SCORE >= 50 ? color.red :
            CPI_SCORE >= 35 ? color.orange :
            CPI_SCORE >= 20 ? color.yellow : color.teal

tsi_color = TSI_SCORE >= 65 ? color.red :
            TSI_SCORE >= 45 ? color.orange :
            TSI_SCORE >= 25 ? color.yellow : color.teal

avi_color = AVI_SCORE >= 70 ? color.red :
            AVI_SCORE >= 60 ? color.orange :
            AVI_SCORE >= 50 ? color.yellow : color.teal

// ── Plots ──
// CPI: filled histogram (primary risk gauge)
plot(CPI_SCORE, "CPI (Crash Prob)", color=color.new(cpi_color, 40),
     style=plot.style_columns, linewidth=1)

// TSI: solid line
plot(TSI_SCORE, "TSI (Tech Stress)", color=tsi_color,
     style=plot.style_line, linewidth=2)

// AVI × 10: dashed line
plot(AVI_SCORE, "AVI × 10 (Valuation)", color=avi_color,
     style=plot.style_line, linewidth=2, linestyle=plot.style_linebr)

// ── Threshold Lines ──
hline(70, "Critical", color=color.new(color.red, 50),    linestyle=hline.style_dashed)
hline(50, "High",     color=color.new(color.red, 70),    linestyle=hline.style_dotted)
hline(35, "Elevated", color=color.new(color.orange, 50), linestyle=hline.style_dashed)
hline(20, "Moderate", color=color.new(color.yellow, 60), linestyle=hline.style_dotted)

// ── Zone Background ──
h_top    = hline(100, color=color.new(color.white, 100))
h_crit   = hline(70,  color=color.new(color.white, 100))
h_high   = hline(50,  color=color.new(color.white, 100))
h_elev   = hline(35,  color=color.new(color.white, 100))
h_mod    = hline(20,  color=color.new(color.white, 100))
h_bottom = hline(0,   color=color.new(color.white, 100))

fill(h_top,    h_crit,   color=color.new(color.red, 95))
fill(h_crit,   h_high,   color=color.new(color.red, 96))
fill(h_high,   h_elev,   color=color.new(color.orange, 95))
fill(h_elev,   h_mod,    color=color.new(color.yellow, 95))
fill(h_mod,    h_bottom, color=color.new(color.green, 95))

// ── Summary Table ──
var table dash = table.new(position.top_right, 3, 5,
                            bgcolor=color.new(#1e222d, 5),
                            border_width=1,
                            border_color=color.new(#363a45, 0))

if barstate.islast
    // Header
    table.cell(dash, 0, 0, "Index",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 0, "Score",  text_color=color.gray, text_size=size.small)
    table.cell(dash, 2, 0, "Level",  text_color=color.gray, text_size=size.small)

    // CPI row
    table.cell(dash, 0, 1, "CPI",
               text_color=color.new(color.white, 10), text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(CPI_SCORE, "#.0") + "/100",
               text_color=cpi_color, text_size=size.small)
    table.cell(dash, 2, 1, CPI_LEVEL,
               text_color=cpi_color, text_size=size.small)

    // TSI row
    table.cell(dash, 0, 2, "TSI",
               text_color=color.new(color.white, 10), text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(TSI_SCORE, "#.0") + "/100",
               text_color=tsi_color, text_size=size.small)
    table.cell(dash, 2, 2, TSI_BIAS,
               text_color=tsi_color, text_size=size.small)

    // AVI row
    table.cell(dash, 0, 3, "AVI V5",
               text_color=color.new(color.white, 10), text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(AVI_RAW, "#.00") + "/10",
               text_color=avi_color, text_size=size.small)
    table.cell(dash, 2, 3, AVI_LABEL,
               text_color=avi_color, text_size=size.small)

    // Footer date
    table.cell(dash, 0, 4, "Updated",
               text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, UPDATE_DATE,
               text_color=color.gray, text_size=size.tiny, merge_cells=true)
    table.merge_cells(dash, 1, 4, 2, 4)
