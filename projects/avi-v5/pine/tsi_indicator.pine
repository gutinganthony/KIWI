//@version=5
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//   Tech Stress Index (TSI) — TradingView Overlay
//   Generated by AVI V5 Dashboard
//
//   HOW TO USE:
//   1. Run `python3 scripts/run_dashboard.py --pine` to generate updated
//      values below.
//   2. Copy this entire script and paste into TradingView Pine Editor.
//   3. Click "Add to Chart" — the TSI panel appears below the price chart.
//
//   Note: Pine Script cannot call external APIs. The TSI_SCORE and indicator
//   values below are STATIC snapshots updated by the Python script.
//
//   TSI Levels:
//     0-25:  BULLISH  — Tech sector healthy, potential upside
//     25-45: NEUTRAL  — Standard risk management
//     45-65: CAUTIOUS — Elevated risk, tighten stops
//     65+:   BEARISH  — High probability of tech correction
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

indicator("TSI — Tech Stress Index", overlay=false, precision=1)

// ── Current TSI Values (auto-updated by run_dashboard.py --pine) ──
// {{PINE_VALUES_START}}
TSI_SCORE      = {{TSI_SCORE}}
TSI_DATE       = "{{TSI_DATE}}"
TSI_BIAS       = "{{TSI_BIAS}}"
FLASH_ALERT    = {{FLASH_ALERT}}
FLASH_REASON   = "{{FLASH_REASON}}"

// Indicator signals (0-100)
SIG_SOX_QQQ    = {{SIG_SOX_QQQ}}
SIG_MEMORY     = {{SIG_MEMORY}}
SIG_YIELD      = {{SIG_YIELD}}
SIG_YIELD_30Y  = {{SIG_YIELD_30Y}}
SIG_BEAR_STEEP = {{SIG_BEAR_STEEP}}
SIG_AI_INFRA   = {{SIG_AI_INFRA}}
SIG_BREADTH    = {{SIG_BREADTH}}
SIG_CLOUD_RS   = {{SIG_CLOUD_RS}}
SIG_VIX_TECH   = {{SIG_VIX_TECH}}
// {{PINE_VALUES_END}}

// ── Color Logic ──
score_color = TSI_SCORE >= 65 ? color.red :
              TSI_SCORE >= 45 ? color.orange :
              TSI_SCORE >= 25 ? color.yellow :
                                color.teal

zone_bg = TSI_SCORE >= 65 ? color.new(color.red, 90) :
          TSI_SCORE >= 45 ? color.new(color.orange, 90) :
          TSI_SCORE >= 25 ? color.new(color.yellow, 92) :
                            color.new(color.green, 92)

// ── Plot TSI Score as Histogram ──
plot(TSI_SCORE, "TSI Score", color=score_color, style=plot.style_columns, linewidth=2)

// ── Threshold Lines ──
hline(65, "BEARISH",  color=color.new(color.red, 50),    linestyle=hline.style_dashed)
hline(45, "CAUTIOUS", color=color.new(color.orange, 50), linestyle=hline.style_dashed)
hline(25, "NEUTRAL",  color=color.new(color.yellow, 60), linestyle=hline.style_dotted)

// ── Zone Background ──
h_top    = hline(100, color=color.new(color.white, 100))
h_bear   = hline(65,  color=color.new(color.white, 100))
h_caut   = hline(45,  color=color.new(color.white, 100))
h_neut   = hline(25,  color=color.new(color.white, 100))
h_bottom = hline(0,   color=color.new(color.white, 100))

fill(h_top,    h_bear,   color=color.new(color.red, 93))
fill(h_bear,   h_caut,   color=color.new(color.orange, 93))
fill(h_caut,   h_neut,   color=color.new(color.yellow, 94))
fill(h_neut,   h_bottom, color=color.new(color.green, 94))

// ── Flash Alert ──
if FLASH_ALERT and barstate.islast
    label.new(bar_index, TSI_SCORE + 8, "⚡ FLASH: " + FLASH_REASON,
              color=color.red, textcolor=color.white,
              style=label.style_label_down, size=size.normal)

// ── Score Label ──
if barstate.islast
    label.new(bar_index, TSI_SCORE,
              "TSI: " + str.tostring(TSI_SCORE, "#.0") + " — " + TSI_BIAS +
              "\nDate: " + TSI_DATE,
              color=score_color, textcolor=color.white,
              style=label.style_label_left, size=size.normal)

// ── Info Table ──
var table t = table.new(position.top_right, 2, 11,
                        bgcolor=color.new(#1e222d, 0),
                        border_width=1,
                        border_color=color.new(#363a45, 0))

_cell(tbl, r, name, val) =>
    c = val >= 80 ? color.red : val >= 50 ? color.orange : val >= 25 ? color.yellow : color.teal
    table.cell(tbl, 0, r, name,                        text_color=color.new(color.white, 20), text_size=size.tiny)
    table.cell(tbl, 1, r, str.tostring(val, "#.0"),    text_color=c,                          text_size=size.tiny)

if barstate.islast
    table.cell(t, 0, 0, "Indicator",  text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 0, "Signal",     text_color=color.gray, text_size=size.small)
    _cell(t, 1,  "SOX/QQQ Diverge",  SIG_SOX_QQQ)
    _cell(t, 2,  "Memory Momentum",  SIG_MEMORY)
    _cell(t, 3,  "Yield Shock 10Y",  SIG_YIELD)
    _cell(t, 4,  "30Y Yield Stress", SIG_YIELD_30Y)
    _cell(t, 5,  "Bear Steepening",  SIG_BEAR_STEEP)
    _cell(t, 6,  "AI Infra RS",      SIG_AI_INFRA)
    _cell(t, 7,  "Tech Breadth",     SIG_BREADTH)
    _cell(t, 8,  "Cloud RS",         SIG_CLOUD_RS)
    _cell(t, 9,  "VIX×Tech Corr",   SIG_VIX_TECH)
