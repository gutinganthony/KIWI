//@version=5
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//   Crash Probability Index (CPI) — TradingView Overlay
//   Generated by AVI V5 Dashboard
//
//   HOW TO USE:
//   1. Run `python3 scripts/run_dashboard.py --pine` to generate updated
//      values below.
//   2. Copy this entire script and paste into TradingView Pine Editor.
//   3. Click "Add to Chart" — the CPI panel appears below the price chart.
//
//   Note: Pine Script cannot call external APIs. The CPI_SCORE and indicator
//   values below are STATIC snapshots updated by the Python script.
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

indicator("CPI — Crash Probability Index", overlay=false, precision=1)

// ── Current CPI Values (auto-updated by run_dashboard.py --pine) ──
// {{PINE_VALUES_START}}
CPI_SCORE       = {{CPI_SCORE}}
CPI_DATE        = "{{CPI_DATE}}"
FLASH_ALERT     = {{FLASH_ALERT}}
FLASH_SEVERITY  = "{{FLASH_SEVERITY}}"
AVI_CONTEXT     = {{AVI_CONTEXT}}

// Indicator signals (0-100)
SIG_VIX_TERM    = {{SIG_VIX_TERM}}
SIG_VIX_SPIKE   = {{SIG_VIX_SPIKE}}
SIG_GARCH       = {{SIG_GARCH}}
SIG_CREDIT      = {{SIG_CREDIT}}
SIG_BREADTH     = {{SIG_BREADTH}}
SIG_DISTRIB     = {{SIG_DISTRIB}}
SIG_RSI         = {{SIG_RSI}}
SIG_MA_DIST     = {{SIG_MA_DIST}}
SIG_YIELD       = {{SIG_YIELD}}
SIG_MOMENTUM    = {{SIG_MOMENTUM}}
// {{PINE_VALUES_END}}

// ── Color Zones ──
zone_color = CPI_SCORE >= 50 ? color.new(color.red, 80) :
             CPI_SCORE >= 35 ? color.new(color.orange, 80) :
             CPI_SCORE >= 20 ? color.new(color.yellow, 80) :
                               color.new(color.green, 80)

score_color = CPI_SCORE >= 50 ? color.red :
              CPI_SCORE >= 35 ? color.orange :
              CPI_SCORE >= 20 ? color.yellow :
                                color.teal

// ── Plot CPI Score as Histogram ──
plot(CPI_SCORE, "CPI Score", color=score_color, style=plot.style_columns, linewidth=2)

// ── Threshold Lines ──
hline(70, "CRITICAL", color=color.new(color.red, 50), linestyle=hline.style_dashed)
hline(50, "HIGH",     color=color.new(color.red, 70), linestyle=hline.style_dotted)
hline(35, "ELEVATED", color=color.new(color.orange, 50), linestyle=hline.style_dashed)
hline(20, "MODERATE", color=color.new(color.yellow, 70), linestyle=hline.style_dotted)

// ── Zone Background Fill ──
h_top    = hline(100, color=color.new(color.white, 100))
h_high   = hline(50,  color=color.new(color.white, 100))
h_elev   = hline(35,  color=color.new(color.white, 100))
h_mod    = hline(20,  color=color.new(color.white, 100))
h_bottom = hline(0,   color=color.new(color.white, 100))

fill(h_top,    h_high,   color=color.new(color.red, 92))
fill(h_high,   h_elev,   color=color.new(color.orange, 93))
fill(h_elev,   h_mod,    color=color.new(color.yellow, 94))
fill(h_mod,    h_bottom, color=color.new(color.green, 94))

// ── Flash Alert Label ──
if FLASH_ALERT and barstate.islast
    severity_text = FLASH_SEVERITY == "critical" ? "FLASH ALERT: CRITICAL" : "FLASH ALERT: WARNING"
    alert_color   = FLASH_SEVERITY == "critical" ? color.red : color.orange
    label.new(bar_index, CPI_SCORE + 8, severity_text,
              color=alert_color, textcolor=color.white,
              style=label.style_label_down, size=size.normal)

// ── Score Label (last bar) ──
if barstate.islast
    level_text = CPI_SCORE >= 70 ? "CRITICAL" :
                 CPI_SCORE >= 50 ? "HIGH" :
                 CPI_SCORE >= 35 ? "ELEVATED" :
                 CPI_SCORE >= 20 ? "MODERATE" : "LOW"
    label.new(bar_index, CPI_SCORE,
              "CPI: " + str.tostring(CPI_SCORE, "#.0") + " — " + level_text +
              "\nDate: " + CPI_DATE +
              (AVI_CONTEXT > 0 ? "\nAVI: " + str.tostring(AVI_CONTEXT, "#.0") + "/10" : ""),
              color=score_color, textcolor=color.white,
              style=label.style_label_left, size=size.normal)

// ── Table: Top Indicators ──
var table infoTable = table.new(position.top_right, 2, 12,
                                bgcolor=color.new(#1e222d, 0),
                                border_width=1,
                                border_color=color.new(#363a45, 0))

if barstate.islast
    table.cell(infoTable, 0, 0, "Indicator", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 0, "Signal",    text_color=color.gray, text_size=size.small)

    _add_row(infoTable, 1,  "VIX Term Str",    SIG_VIX_TERM)
    _add_row(infoTable, 2,  "VIX Spike",       SIG_VIX_SPIKE)
    _add_row(infoTable, 3,  "GARCH Gap",       SIG_GARCH)
    _add_row(infoTable, 4,  "Credit Accel",    SIG_CREDIT)
    _add_row(infoTable, 5,  "Breadth Div",     SIG_BREADTH)
    _add_row(infoTable, 6,  "Distrib Days",    SIG_DISTRIB)
    _add_row(infoTable, 7,  "RSI Diverge",     SIG_RSI)
    _add_row(infoTable, 8,  "MA Distance",     SIG_MA_DIST)
    _add_row(infoTable, 9,  "Yield Curve",     SIG_YIELD)
    _add_row(infoTable, 10, "Momentum",        SIG_MOMENTUM)

// Helper function for table rows
_add_row(tbl, row, name, val) =>
    c = val >= 80 ? color.red : val >= 50 ? color.orange : val >= 30 ? color.yellow : color.teal
    table.cell(tbl, 0, row, name,                          text_color=color.new(color.white, 20), text_size=size.tiny)
    table.cell(tbl, 1, row, str.tostring(val, "#.0"),      text_color=c,                          text_size=size.tiny)
